[
  {
    "id": "hook",
    "execute-command": "/root/workspace/dogroo/deploy/deploy.sh",
    "command-working-directory": "/root/workspace/dogroo/deploy",
    "include-command-output-in-response": false,
    "response-message": "queued",
    "pass-arguments-to-command": [
      { "source": "payload", "name": "targets" }
    ],
    "trigger-rule": {
      "match": {
        "type": "value",
        "value": "{{ getenv \"DEPLOY_KEY\" }}",
        "parameter": { "source": "header", "name": "X-Deploy-Key" }
      }
    }
  }
]
